# Copy to .env and edit. Loaded automatically by both the server and the knex CLI.

# Server
PORT=4000

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# First-run admin seed (only used if no admin exists yet)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Database (SQLite)
# Path to the SQLite file. Defaults to <os tmp>/timeforge/db.sqlite if unset.
DATABASE_PATH=./data/timeforge.sqlite

# Backups
# Required to enable the Settings → Backups feature. Generate with:
#   openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=
